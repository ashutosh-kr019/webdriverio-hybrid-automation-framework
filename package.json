{
  "name": "automation-framework",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "clean:allure": "rimraf reports/allure-results reports/allure-report",
    "test:web": "npm run clean:allure && wdio run config/wdio.web.conf.js",
    "test:api": "npm run clean:allure && mocha test/api/**/*.js --reporter mocha-multi-reporters --reporter-options configFile=config/reporters.json --timeout 10000",
    "test:mobile": "npm run clean:allure && wdio run config/wdio.mobile.conf.js",
    "report:allure": "allure generate reports/allure-results --clean -o reports/allure-report",
    "open:allure": "npx allure-commandline open reports/allure-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@wdio/allure-reporter": "^9.28.0",
    "@wdio/cli": "^9.28.0",
    "@wdio/cucumber-framework": "^9.28.0",
    "@wdio/local-runner": "^9.28.0",
    "@wdio/mocha-framework": "^9.28.0",
    "@wdio/spec-reporter": "^9.28.0",
    "@wdio/visual-service": "^9.2.3",
    "allure-commandline": "^2.42.1",
    "allure-mocha": "^3.10.0",
    "appium-uiautomator2-driver": "^7.6.1",
    "mocha": "^11.7.6",
    "mocha-multi-reporters": "^1.5.1",
    "multiple-cucumber-html-reporter": "^4.0.0",
    "rimraf": "^6.1.3"
  },
  "dependencies": {
    "@wdio/appium-service": "^9.28.0",
    "ajv": "^8.20.0",
    "appium": "^3.5.0",
    "axios": "^1.18.0",
    "chai": "^6.2.2",
    "dotenv": "^17.4.2",
    "winston": "^3.19.0"
  }
}
